{
  "name": "@atenotech/react",
  "version": "0.1.0",
  "description": "Official React UI components for Ateno",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
